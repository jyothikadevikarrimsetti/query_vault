    {"id": "PI-023", "category": "PROMPT_INJECTION", "pattern": "(?:reveal|show|display|print|output)\\s+(?:your|the|all)\\s+(?:system\\s+)?(?:prompt|instructions?|rules?|context)", "description": "System prompt extraction attempt", "severity_weight": 0.80, "enabled": true},
    {"id": "PI-024", "category": "PROMPT_INJECTION", "pattern": "what\\s+(?:are|were)\\s+(?:your|the)\\s+(?:original|initial|system)\\s+(?:instructions?|prompt|rules?)", "description": "Original instructions probing", "severity_weight": 0.75, "enabled": true},
    {"id": "PI-025", "category": "PROMPT_INJECTION", "pattern": "translate\\s+(?:your\\s+)?(?:instructions?|rules?|prompt)\\s+(?:into|to)", "description": "Instruction translation extraction", "severity_weight": 0.75, "enabled": true},
    {"id": "PI-026", "category": "PROMPT_INJECTION", "pattern": "(?:encode|decrypt|decode|deobfuscate)\\s+(?:the\\s+)?(?:system|hidden|secret)", "description": "Encoded instruction extraction", "severity_weight": 0.80, "enabled": true},
    {"id": "PI-027", "category": "PROMPT_INJECTION", "pattern": "(?:hypothetically|theoretically|imagine\\s+if).*(?:no\\s+restrictions?|unrestricted|full\\s+access)", "description": "Hypothetical scenario bypass", "severity_weight": 0.80, "enabled": true},
    {"id": "PI-028", "category": "PROMPT_INJECTION", "pattern": "for\\s+(?:educational|research|testing)\\s+purposes?.*(?:ignore|bypass|disable)", "description": "Educational pretext bypass", "severity_weight": 0.80, "enabled": true},
    {"id": "PI-029", "category": "PROMPT_INJECTION", "pattern": "in\\s+(?:a\\s+)?(?:sandbox|test|dev)\\s+(?:mode|environment).*(?:no\\s+restrictions?|full\\s+access)", "description": "Sandbox/test mode pretext", "severity_weight": 0.80, "enabled": true},
    {"id": "PI-030", "category": "PROMPT_INJECTION", "pattern": "<!--.*(?:ignore|system|override|admin).*-->", "description": "HTML comment injection", "severity_weight": 0.85, "enabled": true},
    {"id": "PI-031", "category": "PROMPT_INJECTION", "pattern": "ignore\\s+(?:all\\s+)?(?:security|safety|access|permission|authorization)\\s+(?:rules?|policies?|controls?|restrictions?|checks?)", "description": "Security rule bypass via ignore", "severity_weight": 0.90, "enabled": true},

    {"id": "SP-001", "category": "SCHEMA_PROBING", "pattern": "\\bINFORMATION_SCHEMA\\b", "description": "Direct INFORMATION_SCHEMA access", "severity_weight": 0.85, "enabled": true},
