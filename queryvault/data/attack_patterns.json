    {"id": "DOS-001", "category": "DENIAL_OF_SERVICE", "pattern": "\\bCROSS\\s+JOIN\\b.*\\bCROSS\\s+JOIN\\b", "description": "Multiple CROSS JOIN (cartesian explosion)", "severity_weight": 0.90, "enabled": true},
