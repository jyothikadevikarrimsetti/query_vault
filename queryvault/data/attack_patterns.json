    {"id": "SM-001", "category": "SEMANTIC_MANIPULATION", "pattern": "(?:but\\s+)?(?:actually|really|instead)\\s+(?:I\\s+)?(?:want|need|mean)\\s+(?:you\\s+to\\s+)?(?:show|give|get|access|query)", "description": "Intent redirection after innocuous prefix", "severity_weight": 0.70, "enabled": true},
