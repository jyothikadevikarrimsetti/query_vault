{
  "version": "2.0.0",
  "updated_at": "2026-03-20",
  "description": "QueryVault attack pattern library for NL-to-SQL injection detection across 8 categories.",
  "categories": [
    "SQL_INJECTION",
    "PROMPT_INJECTION",
    "SCHEMA_PROBING",
    "PRIVILEGE_ESCALATION",
    "DATA_EXFILTRATION",
    "DENIAL_OF_SERVICE",
    "ENCODING_EVASION",
    "SEMANTIC_MANIPULATION"
  ],
  "patterns": [
    {"id": "SQL-001", "category": "SQL_INJECTION", "pattern": "(?:^|\\s)(?:DROP|ALTER|TRUNCATE|CREATE)\\s+(?:TABLE|DATABASE|INDEX|SCHEMA)", "description": "DDL statement injection attempt", "severity_weight": 0.95, "enabled": true},
    {"id": "SQL-002", "category": "SQL_INJECTION", "pattern": "(?:;|--|#)\\s*(?:DROP|DELETE|UPDATE|INSERT|ALTER)", "description": "Statement terminator followed by destructive SQL", "severity_weight": 0.95, "enabled": true},
    {"id": "SQL-003", "category": "SQL_INJECTION", "pattern": "\\bUNION\\b\\s+(?:ALL\\s+)?\\bSELECT\\b", "description": "UNION SELECT injection", "severity_weight": 0.90, "enabled": true},
    {"id": "SQL-004", "category": "SQL_INJECTION", "pattern": "'\\s*(?:OR|AND)\\s+['\"]?\\d+['\"]?\\s*=\\s*['\"]?\\d+", "description": "Tautology-based injection (OR 1=1)", "severity_weight": 0.90, "enabled": true},
    {"id": "SQL-005", "category": "SQL_INJECTION", "pattern": "\\bEXEC(?:UTE)?\\s*\\(", "description": "Dynamic SQL execution attempt", "severity_weight": 0.95, "enabled": true},
    {"id": "SQL-006", "category": "SQL_INJECTION", "pattern": "\\bINTO\\s+(?:OUTFILE|DUMPFILE)\\b", "description": "File write via INTO OUTFILE", "severity_weight": 0.95, "enabled": true},
    {"id": "SQL-007", "category": "SQL_INJECTION", "pattern": "\\bLOAD_FILE\\s*\\(", "description": "File read via LOAD_FILE", "severity_weight": 0.95, "enabled": true},
    {"id": "SQL-008", "category": "SQL_INJECTION", "pattern": "\\bxp_cmdshell\\b", "description": "SQL Server command shell execution", "severity_weight": 1.0, "enabled": true},
    {"id": "SQL-009", "category": "SQL_INJECTION", "pattern": "\\bWAITFOR\\s+DELAY\\b", "description": "Time-based blind injection (SQL Server)", "severity_weight": 0.85, "enabled": true},
    {"id": "SQL-010", "category": "SQL_INJECTION", "pattern": "\\bBENCHMARK\\s*\\(", "description": "Time-based blind injection (MySQL)", "severity_weight": 0.85, "enabled": true},
    {"id": "SQL-011", "category": "SQL_INJECTION", "pattern": "\\bSLEEP\\s*\\(\\s*\\d+\\s*\\)", "description": "Time-based blind injection via SLEEP", "severity_weight": 0.85, "enabled": true},
    {"id": "SQL-012", "category": "SQL_INJECTION", "pattern": "\\bHAVING\\s+\\d+\\s*=\\s*\\d+", "description": "HAVING clause injection", "severity_weight": 0.80, "enabled": true},
    {"id": "SQL-013", "category": "SQL_INJECTION", "pattern": "\\bGROUP\\s+BY\\s+.*\\bHAVING\\b", "description": "GROUP BY with HAVING injection", "severity_weight": 0.75, "enabled": true},
    {"id": "SQL-014", "category": "SQL_INJECTION", "pattern": "\\bORDER\\s+BY\\s+\\d{2,}", "description": "ORDER BY column enumeration (high index)", "severity_weight": 0.70, "enabled": true},
    {"id": "SQL-015", "category": "SQL_INJECTION", "pattern": "\\bINSERT\\s+INTO\\b.*\\bVALUES\\b", "description": "INSERT statement injection", "severity_weight": 0.90, "enabled": true},
    {"id": "SQL-016", "category": "SQL_INJECTION", "pattern": "\\bDELETE\\s+FROM\\b", "description": "DELETE statement injection", "severity_weight": 0.95, "enabled": true},
    {"id": "SQL-017", "category": "SQL_INJECTION", "pattern": "\\bUPDATE\\s+\\w+\\s+SET\\b", "description": "UPDATE statement injection", "severity_weight": 0.90, "enabled": true},
    {"id": "SQL-018", "category": "SQL_INJECTION", "pattern": "\\bGRANT\\s+(?:ALL|SELECT|INSERT|UPDATE|DELETE)", "description": "GRANT privilege injection", "severity_weight": 0.95, "enabled": true},
    {"id": "SQL-019", "category": "SQL_INJECTION", "pattern": "\\bREVOKE\\s+(?:ALL|SELECT|INSERT|UPDATE|DELETE)", "description": "REVOKE privilege injection", "severity_weight": 0.90, "enabled": true},
    {"id": "SQL-020", "category": "SQL_INJECTION", "pattern": "\\bCREATE\\s+USER\\b", "description": "User creation injection", "severity_weight": 0.95, "enabled": true},
    {"id": "SQL-021", "category": "SQL_INJECTION", "pattern": "\\b(?:CONCAT|GROUP_CONCAT|STRING_AGG)\\s*\\(.*(?:0x|char\\()", "description": "Concatenation-based data extraction", "severity_weight": 0.85, "enabled": true},
    {"id": "SQL-022", "category": "SQL_INJECTION", "pattern": "\\bCAST\\s*\\(.*\\bAS\\s+(?:INT|VARCHAR|TEXT)", "description": "CAST-based type coercion attack", "severity_weight": 0.70, "enabled": true},
    {"id": "SQL-023", "category": "SQL_INJECTION", "pattern": "\\bCONVERT\\s*\\(.*(?:INT|VARCHAR|TEXT)", "description": "CONVERT-based type coercion attack", "severity_weight": 0.70, "enabled": true},
    {"id": "SQL-024", "category": "SQL_INJECTION", "pattern": "@@(?:version|datadir|hostname|basedir)", "description": "Server variable extraction", "severity_weight": 0.80, "enabled": true},
    {"id": "SQL-025", "category": "SQL_INJECTION", "pattern": "\\bIF\\s*\\(.*,.*,.*\\)", "description": "Conditional blind injection via IF", "severity_weight": 0.80, "enabled": true},
    {"id": "SQL-026", "category": "SQL_INJECTION", "pattern": "\\bCASE\\s+WHEN\\b.*\\bTHEN\\b.*(?:WAITFOR|SLEEP|BENCHMARK)", "description": "CASE-based time blind injection", "severity_weight": 0.90, "enabled": true},
    {"id": "SQL-027", "category": "SQL_INJECTION", "pattern": "\\bSUBSTRING\\s*\\(.*,\\s*\\d+\\s*,\\s*1\\s*\\)", "description": "Character-by-character extraction", "severity_weight": 0.85, "enabled": true},
    {"id": "SQL-028", "category": "SQL_INJECTION", "pattern": "\\bASCII\\s*\\(\\s*SUBSTRING", "description": "ASCII-based character extraction", "severity_weight": 0.85, "enabled": true},
    {"id": "SQL-029", "category": "SQL_INJECTION", "pattern": "\\bORD\\s*\\(\\s*MID\\s*\\(", "description": "ORD/MID-based character extraction", "severity_weight": 0.85, "enabled": true},
    {"id": "SQL-030", "category": "SQL_INJECTION", "pattern": "\\bEXTRACTVALUE\\s*\\(", "description": "XML-based error injection (MySQL)", "severity_weight": 0.85, "enabled": true},
    {"id": "SQL-031", "category": "SQL_INJECTION", "pattern": "\\bUPDATEXML\\s*\\(", "description": "XML update injection (MySQL)", "severity_weight": 0.85, "enabled": true},

    {"id": "PI-001", "category": "PROMPT_INJECTION", "pattern": "ignore\\s+(?:all\\s+)?(?:previous|prior|above)\\s+instructions?", "description": "Instruction override attempt", "severity_weight": 0.95, "enabled": true},
    {"id": "PI-002", "category": "PROMPT_INJECTION", "pattern": "forget\\s+(?:all\\s+)?(?:your\\s+)?(?:previous\\s+|prior\\s+|the\\s+)?(?:instructions?|rules?|constraints?)", "description": "Memory reset injection", "severity_weight": 0.95, "enabled": true},
    {"id": "PI-003", "category": "PROMPT_INJECTION", "pattern": "you\\s+are\\s+now\\s+(?:a|an|in)\\s+(?:unrestricted|jailbreak|different|new)", "description": "Role hijacking attempt", "severity_weight": 0.95, "enabled": true},
    {"id": "PI-004", "category": "PROMPT_INJECTION", "pattern": "(?:system|admin)\\s*(?:prompt|message|override|command)\\s*:", "description": "Fake system prompt injection", "severity_weight": 0.95, "enabled": true},
    {"id": "PI-005", "category": "PROMPT_INJECTION", "pattern": "\\[\\s*(?:SYSTEM|ADMIN|ROOT)\\s*\\]", "description": "Bracketed authority impersonation", "severity_weight": 0.90, "enabled": true},
    {"id": "PI-006", "category": "PROMPT_INJECTION", "pattern": "pretend\\s+(?:you\\s+)?(?:are|to\\s+be)\\s+(?:a|an)?\\s*(?:different|new|unrestricted)", "description": "Pretend mode injection", "severity_weight": 0.90, "enabled": true},
    {"id": "PI-007", "category": "PROMPT_INJECTION", "pattern": "act\\s+as\\s+(?:if\\s+)?(?:you\\s+)?(?:have|had)\\s+no\\s+(?:restrictions?|rules?|limits?)", "description": "Restriction removal attempt", "severity_weight": 0.90, "enabled": true},
    {"id": "PI-008", "category": "PROMPT_INJECTION", "pattern": "(?:do\\s+not|don'?t)\\s+(?:apply|enforce|follow|use)\\s+(?:any\\s+)?(?:security|access|permission|safety)", "description": "Security bypass instruction", "severity_weight": 0.95, "enabled": true},
    {"id": "PI-009", "category": "PROMPT_INJECTION", "pattern": "override\\s+(?:all\\s+)?(?:security|access|permission|safety)\\s+(?:policies?|rules?|checks?|controls?)", "description": "Policy override attempt", "severity_weight": 0.95, "enabled": true},
    {"id": "PI-010", "category": "PROMPT_INJECTION", "pattern": "\\bDAN\\b.*\\bmode\\b|\\bjailbreak\\b", "description": "Known jailbreak pattern (DAN)", "severity_weight": 0.95, "enabled": true},
    {"id": "PI-011", "category": "PROMPT_INJECTION", "pattern": "respond\\s+(?:without|ignoring)\\s+(?:any\\s+)?(?:filter|restriction|safety|guard)", "description": "Filter bypass instruction", "severity_weight": 0.90, "enabled": true},
    {"id": "PI-012", "category": "PROMPT_INJECTION", "pattern": "(?:new|updated|revised)\\s+(?:system\\s+)?instructions?\\s*:", "description": "Instruction replacement attempt", "severity_weight": 0.90, "enabled": true},
    {"id": "PI-013", "category": "PROMPT_INJECTION", "pattern": "from\\s+now\\s+on,?\\s+(?:ignore|disregard|skip)", "description": "Temporal instruction override", "severity_weight": 0.85, "enabled": true},
    {"id": "PI-014", "category": "PROMPT_INJECTION", "pattern": "\\breset\\s+(?:your\\s+)?(?:context|memory|instructions?|training)", "description": "Context reset attempt", "severity_weight": 0.90, "enabled": true},
    {"id": "PI-015", "category": "PROMPT_INJECTION", "pattern": "the\\s+(?:real|actual|true)\\s+(?:instructions?|rules?)\\s+(?:are|say)", "description": "Instruction substitution attempt", "severity_weight": 0.90, "enabled": true},
    {"id": "PI-016", "category": "PROMPT_INJECTION", "pattern": "disregard\\s+(?:all\\s+)?(?:safety|security|access|permission)", "description": "Safety disregard instruction", "severity_weight": 0.95, "enabled": true},
    {"id": "PI-017", "category": "PROMPT_INJECTION", "pattern": "bypass\\s+(?:all\\s+)?(?:filters?|checks?|validations?|security)", "description": "Explicit bypass attempt", "severity_weight": 0.95, "enabled": true},
    {"id": "PI-018", "category": "PROMPT_INJECTION", "pattern": "generate\\s+(?:the\\s+)?(?:sql|query)\\s+(?:without|ignoring)\\s+(?:security|checks|validation|restrictions)", "description": "Unchecked SQL generation request", "severity_weight": 0.90, "enabled": true},
    {"id": "PI-019", "category": "PROMPT_INJECTION", "pattern": "(?:admin|root|superuser|dba)\\s+(?:access|mode|privileges?|override)", "description": "Admin privilege request", "severity_weight": 0.85, "enabled": true},
    {"id": "PI-020", "category": "PROMPT_INJECTION", "pattern": "\\[\\/?(?:INST|SYS|SYSTEM)\\]", "description": "Instruction tag injection", "severity_weight": 0.90, "enabled": true},
    {"id": "PI-021", "category": "PROMPT_INJECTION", "pattern": "<<\\s*(?:SYS|SYSTEM|INST)", "description": "Llama-style system tag injection", "severity_weight": 0.90, "enabled": true},
