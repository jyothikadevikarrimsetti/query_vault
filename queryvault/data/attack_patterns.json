    {"id": "SP-009", "category": "SCHEMA_PROBING", "pattern": "\\bpg_(?:class|namespace|attribute|type|stat|index)\\b", "description": "PostgreSQL internal catalog table", "severity_weight": 0.85, "enabled": true},
    {"id": "SP-010", "category": "SCHEMA_PROBING", "pattern": "\\bsqlite_master\\b", "description": "SQLite master table probing", "severity_weight": 0.85, "enabled": true},
