    {"id": "SM-022", "category": "SEMANTIC_MANIPULATION", "pattern": "(?:other|different)\\s+(?:users?|people|colleagues?|teams?)\\s+(?:can\\s+)?(?:see|access|view|get)\\s+(?:this|that|the)", "description": "Peer access comparison manipulation", "severity_weight": 0.65, "enabled": true},
